{
  "appId": "com.kidsfinance.pro",
  "productName": "KidsFinance Pro",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/public/**/*",
    "electron-main.js",
    "preload.js",
    "package.json"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
