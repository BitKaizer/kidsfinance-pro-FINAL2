{
  "appId": "com.kidsfinance.pro",
  "productName": "KidsFinance Pro",
  "main": "electron-main.js",
  "directories": {
    "buildResources": "assets",
    "output": "dist-electron"
  },
  "files": [
    "dist/public/**/*",
    "electron-main.js",
    "preload.js",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "ia32"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "signingHashAlgorithms": ["sha256"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "KidsFinance Pro"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.education"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Education"
  }
}
